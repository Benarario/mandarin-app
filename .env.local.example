# ── Copy this file to ".env.local" and fill in the values. ──
# SETUP.md walks you through getting each of these in plain language.

# From Supabase → Project Settings → Data API (or "API")
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# From Supabase → Project Settings → API → "service_role" secret.
# Used ONLY by the one-time data loader scripts on your computer.
# It is never sent to the browser. Keep it secret; never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Text-to-speech (Chinese audio) ──
# Phase 1 uses the free, no-signup edge-tts in development — nothing to set here.
# Azure is wired in Phase 2; these stay blank for now.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
